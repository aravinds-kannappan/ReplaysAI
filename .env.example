# All keys are OPTIONAL. With none set, the app runs on real ESPN data with
# deterministic, data-backed text and an ephemeral (non-persisted) picks/leaderboard.

# LLM (recaps, reels, what-ifs, chat, and the newsletter/broadcast fallback).
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Highlight search.
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# Durable store (Upstash / Vercel KV). Powers real picks scoring, the leaderboard,
# gamification, and newsletter share links. Without it those degrade gracefully.
REDIS_URL=redis://localhost:6379

# Trained agents (see training/README.md). OpenAI-compatible endpoint of the
# fine-tuned newsletter + broadcast writers (Baseten / Orthogonal). Unset = the
# surfaces fall back to the Anthropic LLM, then the deterministic template.
TRAINED_BASE_URL=
TRAINED_API_KEY=
NEWSLETTER_MODEL=
BROADCAST_MODEL=

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
